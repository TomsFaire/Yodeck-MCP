# Copy to .env and set your token (Premium/Enterprise API).
# In a shell: set -a && source .env && set +a
#   curl -s -H "Authorization: Token $YODECK_API_TOKEN" https://app.yodeck.com/api/v2/
# Optional Claude Code permissions template:
#   cp .claude/settings.local.example.json .claude/settings.local.json
YODECK_API_TOKEN=
